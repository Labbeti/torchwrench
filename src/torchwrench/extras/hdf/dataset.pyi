import types
from functools import cached_property as cached_property
from pathlib import Path
from typing import Any, Callable, Generic, Iterable, TypeVar, overload

import numpy as np
from _typeshed import Incomplete
from torch import Tensor
from typing_extensions import Self, TypeAlias

from torchwrench.extras.hdf.common import HDFDatasetAttributes as HDFDatasetAttributes
from torchwrench.extras.hdf.common import HDFItemType as HDFItemType
from torchwrench.extras.numpy.scan_info import (
    numpy_dtype_to_torch_dtype as numpy_dtype_to_torch_dtype,
)
from torchwrench.nn.functional.indices import get_inverse_perm as get_inverse_perm
from torchwrench.serialization.common import as_builtin as as_builtin
from torchwrench.types._typing import ScalarLike as ScalarLike
from torchwrench.types.guards import is_scalar_like as is_scalar_like
from torchwrench.utils.data.dataset.slicer import DatasetSlicer as DatasetSlicer

T = TypeVar("T", covariant=True)
U = TypeVar("U", covariant=False)
IndexLike: TypeAlias = int | Iterable[int] | Tensor | slice | None
ColumnLike: TypeAlias = str | Iterable[str] | None
CastMode: Incomplete
pylog: Incomplete

class HDFDataset(DatasetSlicer[U], Generic[T, U]):
    def __init__(
        self,
        hdf_fpath: str | Path,
        *,
        transform: Callable[[T], U] | None = ...,
        keep_padding: Iterable[str] = (),
        return_added_columns: bool = False,
        open_hdf: bool = True,
        cast: CastMode = "none",
        file_kwds: dict[str, Any] | None = None,
    ) -> None: ...
    @property
    def added_columns(self) -> list[str]: ...
    @property
    def all_columns(self) -> list[str]: ...
    @cached_property
    def attrs(self) -> HDFDatasetAttributes: ...
    @property
    def column_names(self) -> tuple[str, ...]: ...
    @property
    def info(self) -> dict[str, Any]: ...
    @property
    def item_type(self) -> HDFItemType: ...
    @property
    def keep_padding(self) -> list[str]: ...
    @keep_padding.setter
    def keep_padding(self, new_value: Iterable[str]) -> None: ...
    @property
    def num_columns(self) -> int: ...
    @property
    def num_rows(self) -> int: ...
    @property
    def shape(self) -> tuple[int, ...]: ...
    @property
    def transform(self) -> Callable[[T], U] | None: ...
    @property
    def user_attrs(self) -> Any: ...
    def at(self, *args, **kwargs) -> Any: ...
    def close(
        self, ignore_if_closed: bool = False, remove_file: bool = False
    ) -> None: ...
    def get_attrs(self) -> HDFDatasetAttributes: ...
    def get_hdf_fpath(self) -> Path: ...
    def get_hdf_keys(self) -> tuple[str, ...]: ...
    def get_column_shape(self, column_name: str) -> tuple[int, ...]: ...
    def get_columns_shapes(self) -> dict[str, tuple[int, ...]]: ...
    def get_column_dtype(self, column_name: str) -> np.dtype: ...
    @overload
    def get_item(self, index: int, column: None = None) -> U: ...
    @overload
    def get_item(self, index: Iterable[int] | slice | None, column: str) -> list: ...
    @overload
    def get_item(
        self, index: Iterable[int] | slice | None, column: list[str] | None = None
    ) -> dict[str, list]: ...
    @overload
    def get_item(self, index: Any, column: Any, raw: bool = False) -> Any: ...
    def is_closed(self) -> bool: ...
    def is_open(self) -> bool: ...
    def keys(self) -> tuple[str, ...]: ...
    def open(self, ignore_if_opened: bool = False) -> None: ...
    def to_dict(self, raw: bool = False) -> dict[str, np.ndarray]: ...
    def __eq__(self, __o: object) -> bool: ...
    def __enter__(self) -> Self: ...
    def __exit__(self, *args, **kwargs) -> None: ...
    @overload
    def __getitem__(self, index: int) -> U: ...
    @overload
    def __getitem__(self, index: str) -> np.ndarray: ...
    @overload
    def __getitem__(self, index: tuple[IndexLike, str]) -> np.ndarray: ...
    @overload
    def __getitem__(
        self, index: Iterable[int] | list[str] | tuple[str, ...] | slice | None
    ) -> dict[str, np.ndarray]: ...
    @overload
    def __getitem__(self, index: Any) -> Any: ...
    def __hash__(self) -> int: ...
    def __len__(self) -> int: ...
